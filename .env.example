# Copy this file to .env.local for dev, and into your Vercel project's
# Environment Variables for production.

# ---------------------------------------------------------------- Sanity (CMS)
# From sanity.io → your project → API.
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"

# ---------------------------------------------------------------- Polar (checkout)
# From polar.sh → Settings → Tokens.
# Use a sandbox token at sandbox.polar.sh while testing.
POLAR_ACCESS_TOKEN="polar_oat_..."
POLAR_SERVER="production"  # or "sandbox"

# ---------------------------------------------------------------- Site URL
# Used by sitemap, robots, Open Graph, and the Polar success redirect.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ---------------------------------------------------------------- Sanity webhook
# Any long random string. Set the same value in
#   sanity.io → API → Webhooks → (your webhook) → Secret
# so content updates revalidate the site instantly.
SANITY_REVALIDATE_SECRET="long-random-string"
